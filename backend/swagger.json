{
  "openapi": "3.0.3",
  "info": {
    "title": "WorkForcePro API",
    "version": "1.0.0",
    "description": "RESTful API for managing employees, trainings, certifications, and departments in a workforce management system."
  },
  "servers": [
    {
      "url": "http://localhost:3001",
      "description": "Local development server"
    }
  ],
  "tags": [
    { "name": "Health", "description": "Server health checks" },
    { "name": "Departments", "description": "Department management" },
    { "name": "Employees", "description": "Employee management" },
    { "name": "Trainings", "description": "Training management and assignments" },
    { "name": "Certifications", "description": "Certification management" }
  ],
  "paths": {
    "/api/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check",
        "operationId": "healthCheck",
        "responses": {
          "200": {
            "description": "Server is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "ok" },
                    "timestamp": { "type": "string", "format": "date-time", "example": "2026-06-25T12:00:00.000Z" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/departments": {
      "get": {
        "tags": ["Departments"],
        "summary": "List all departments",
        "operationId": "getDepartments",
        "responses": {
          "200": {
            "description": "List of departments",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Department" }
                }
              }
            }
          },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/api/employees": {
      "get": {
        "tags": ["Employees"],
        "summary": "List all employees",
        "operationId": "getEmployees",
        "responses": {
          "200": {
            "description": "List of employees with department and supervisor info",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Employee" }
                }
              }
            }
          },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      },
      "post": {
        "tags": ["Employees"],
        "summary": "Create a new employee",
        "operationId": "createEmployee",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateEmployeeRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Employee created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Employee" }
              }
            }
          },
          "400": {
            "description": "Validation error or invalid supervisor",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/api/employees/supervisors": {
      "get": {
        "tags": ["Employees"],
        "summary": "List all supervisors",
        "operationId": "getSupervisors",
        "responses": {
          "200": {
            "description": "List of employees with supervisor privileges",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Supervisor" }
                }
              }
            }
          },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/api/employees/{id}": {
      "get": {
        "tags": ["Employees"],
        "summary": "Get a single employee",
        "operationId": "getEmployee",
        "parameters": [
          { "$ref": "#/components/parameters/EmployeeId" }
        ],
        "responses": {
          "200": {
            "description": "Employee details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Employee" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      },
      "put": {
        "tags": ["Employees"],
        "summary": "Update an employee",
        "operationId": "updateEmployee",
        "parameters": [
          { "$ref": "#/components/parameters/EmployeeId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateEmployeeRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Employee updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Employee" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      },
      "delete": {
        "tags": ["Employees"],
        "summary": "Delete an employee",
        "operationId": "deleteEmployee",
        "parameters": [
          { "$ref": "#/components/parameters/EmployeeId" }
        ],
        "responses": {
          "204": { "description": "Employee deleted, no content" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/api/employees/{id}/trainings": {
      "get": {
        "tags": ["Employees", "Trainings"],
        "summary": "Get trainings for an employee",
        "operationId": "getEmployeeTrainings",
        "parameters": [
          { "$ref": "#/components/parameters/EmployeeId" }
        ],
        "responses": {
          "200": {
            "description": "Employee training assignments",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/EmployeeTraining" }
                }
              }
            }
          },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/api/employees/{id}/certifications": {
      "get": {
        "tags": ["Employees", "Certifications"],
        "summary": "Get certifications for an employee",
        "operationId": "getEmployeeCertifications",
        "parameters": [
          { "$ref": "#/components/parameters/EmployeeId" }
        ],
        "responses": {
          "200": {
            "description": "Employee certifications",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Certification" }
                }
              }
            }
          },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/api/trainings": {
      "get": {
        "tags": ["Trainings"],
        "summary": "List all trainings",
        "operationId": "getTrainings",
        "responses": {
          "200": {
            "description": "List of training modules",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Training" }
                }
              }
            }
          },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/api/trainings/employee/{employee_id}": {
      "get": {
        "tags": ["Trainings"],
        "summary": "Get trainings for a specific employee",
        "operationId": "getTrainingsByEmployee",
        "parameters": [
          { "$ref": "#/components/parameters/EmployeeNumericId" }
        ],
        "responses": {
          "200": {
            "description": "Employee training assignments",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/EmployeeTraining" }
                }
              }
            }
          },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/api/trainings/assign": {
      "post": {
        "tags": ["Trainings"],
        "summary": "Assign training to an employee (supervisor only)",
        "operationId": "assignTraining",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AssignTrainingRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Training assigned",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EmployeeTraining" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "403": {
            "description": "Only supervisors can assign training",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/api/trainings/complete": {
      "post": {
        "tags": ["Trainings"],
        "summary": "Mark training as completed",
        "operationId": "completeTraining",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CompleteTrainingRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Training marked as completed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EmployeeTraining" }
              }
            }
          },
          "201": {
            "description": "Training completed without prior assignment",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/EmployeeTraining" },
                    {
                      "type": "object",
                      "properties": {
                        "warning": {
                          "type": "string",
                          "example": "Training was not assigned but was completed anyway"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/api/trainings/approve": {
      "post": {
        "tags": ["Trainings"],
        "summary": "Approve completed training (supervisor only)",
        "operationId": "approveTraining",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TrainingActionRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Training approved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EmployeeTraining" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "403": {
            "description": "Only supervisors can approve training",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/api/trainings/reject": {
      "post": {
        "tags": ["Trainings"],
        "summary": "Reject training (supervisor only)",
        "operationId": "rejectTraining",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TrainingActionRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Training rejected",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Training rejected" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "403": {
            "description": "Only supervisors can reject training",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/api/trainings/{id}": {
      "get": {
        "tags": ["Trainings"],
        "summary": "Get a single training module",
        "operationId": "getTraining",
        "parameters": [
          { "$ref": "#/components/parameters/TrainingId" }
        ],
        "responses": {
          "200": {
            "description": "Training details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Training" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/api/trainings/{id}/assignments": {
      "get": {
        "tags": ["Trainings"],
        "summary": "Get all employees assigned to a training",
        "operationId": "getTrainingAssignments",
        "parameters": [
          { "$ref": "#/components/parameters/TrainingId" }
        ],
        "responses": {
          "200": {
            "description": "List of assignments for the training",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/TrainingAssignment" }
                }
              }
            }
          },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/api/certifications": {
      "get": {
        "tags": ["Certifications"],
        "summary": "List all certifications",
        "operationId": "getCertifications",
        "responses": {
          "200": {
            "description": "List of certifications with employee names",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Certification" }
                }
              }
            }
          },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      },
      "post": {
        "tags": ["Certifications"],
        "summary": "Create a new certification for an employee",
        "operationId": "createCertification",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateCertificationRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Certification created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Certification" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/api/certifications/expiring": {
      "get": {
        "tags": ["Certifications"],
        "summary": "Get expiring certifications (within 30 days)",
        "operationId": "getExpiringCertifications",
        "responses": {
          "200": {
            "description": "List of expiring certifications (or all certifications if none expiring - known bug)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Certification" }
                }
              }
            }
          },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/api/certifications/employee/{employee_id}": {
      "get": {
        "tags": ["Certifications"],
        "summary": "Get certifications for a specific employee",
        "operationId": "getCertificationsByEmployee",
        "parameters": [
          { "$ref": "#/components/parameters/EmployeeNumericId" }
        ],
        "responses": {
          "200": {
            "description": "Employee certifications",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Certification" }
                }
              }
            }
          },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/api/certifications/{id}": {
      "get": {
        "tags": ["Certifications"],
        "summary": "Get a single certification",
        "operationId": "getCertification",
        "parameters": [
          { "$ref": "#/components/parameters/CertificationId" }
        ],
        "responses": {
          "200": {
            "description": "Certification details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Certification" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      },
      "put": {
        "tags": ["Certifications"],
        "summary": "Update a certification",
        "operationId": "updateCertification",
        "parameters": [
          { "$ref": "#/components/parameters/CertificationId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateCertificationRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Certification updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Certification" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      },
      "delete": {
        "tags": ["Certifications"],
        "summary": "Delete a certification",
        "operationId": "deleteCertification",
        "parameters": [
          { "$ref": "#/components/parameters/CertificationId" }
        ],
        "responses": {
          "204": { "description": "Certification deleted, no content" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "EmployeeId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" },
        "description": "Employee database ID"
      },
      "EmployeeNumericId": {
        "name": "employee_id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" },
        "description": "Employee database ID"
      },
      "TrainingId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" },
        "description": "Training database ID"
      },
      "CertificationId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" },
        "description": "Certification database ID"
      }
    },
    "schemas": {
      "Department": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "name": { "type": "string", "example": "Engineering" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "Supervisor": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "employee_id": { "type": "string", "example": "EMP001" },
          "name": { "type": "string", "example": "Jane Smith" },
          "email": { "type": "string", "example": "jane.smith@company.com" }
        }
      },
      "Employee": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "employee_id": { "type": "string", "example": "EMP001" },
          "name": { "type": "string", "example": "John Doe" },
          "email": { "type": "string", "example": "john.doe@company.com" },
          "department_id": { "type": "integer", "nullable": true, "example": 2 },
          "department_name": { "type": "string", "nullable": true, "example": "Engineering" },
          "supervisor_id": { "type": "integer", "nullable": true, "example": 3 },
          "supervisor_name": { "type": "string", "nullable": true, "example": "Jane Smith" },
          "is_supervisor": { "type": "boolean", "example": false },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "CreateEmployeeRequest": {
        "type": "object",
        "required": ["employee_id", "name", "email"],
        "properties": {
          "employee_id": { "type": "string", "example": "EMP010" },
          "name": { "type": "string", "example": "Alice Johnson" },
          "email": { "type": "string", "format": "email", "example": "alice.johnson@company.com" },
          "department_id": { "type": "integer", "nullable": true, "example": 1 },
          "supervisor_id": { "type": "integer", "nullable": true, "example": 3 },
          "is_supervisor": { "type": "boolean", "example": false }
        }
      },
      "UpdateEmployeeRequest": {
        "type": "object",
        "required": ["name", "email"],
        "properties": {
          "name": { "type": "string", "example": "Alice Johnson-Smith" },
          "email": { "type": "string", "format": "email", "example": "alice.johnson@company.com" },
          "department_id": { "type": "integer", "nullable": true, "example": 2 },
          "supervisor_id": { "type": "integer", "nullable": true, "example": 3 },
          "is_supervisor": { "type": "boolean", "example": true }
        }
      },
      "Training": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "training_name": { "type": "string", "example": "Workplace Safety" },
          "description": { "type": "string", "nullable": true, "example": "Annual workplace safety training" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "EmployeeTraining": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 5 },
          "employee_id": { "type": "integer", "example": 2 },
          "training_id": { "type": "integer", "example": 1 },
          "training_name": { "type": "string", "example": "Workplace Safety" },
          "due_date": { "type": "string", "format": "date", "nullable": true, "example": "2026-07-25" },
          "status": {
            "type": "string",
            "enum": ["assigned", "completed", "approved", "rejected"],
            "example": "assigned"
          },
          "completion_date": { "type": "string", "format": "date", "nullable": true, "example": "2026-07-20" },
          "notes": { "type": "string", "nullable": true, "example": "Completed all modules" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "AssignTrainingRequest": {
        "type": "object",
        "required": ["employee_id", "training_id", "supervisor_id"],
        "properties": {
          "employee_id": { "type": "integer", "example": 2 },
          "training_id": { "type": "integer", "example": 1 },
          "due_date": { "type": "string", "format": "date", "example": "2026-07-25" },
          "supervisor_id": { "type": "integer", "example": 3 }
        }
      },
      "CompleteTrainingRequest": {
        "type": "object",
        "required": ["employee_id", "training_id"],
        "properties": {
          "employee_id": { "type": "integer", "example": 2 },
          "training_id": { "type": "integer", "example": 1 },
          "completion_date": { "type": "string", "format": "date", "example": "2026-06-25" },
          "notes": { "type": "string", "example": "Completed all modules successfully" }
        }
      },
      "TrainingActionRequest": {
        "type": "object",
        "required": ["employee_id", "training_id", "supervisor_id"],
        "properties": {
          "employee_id": { "type": "integer", "example": 2 },
          "training_id": { "type": "integer", "example": 1 },
          "supervisor_id": { "type": "integer", "example": 3 }
        }
      },
      "TrainingAssignment": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 5 },
          "employee_id": { "type": "integer", "example": 2 },
          "employee_name": { "type": "string", "example": "John Doe" },
          "training_id": { "type": "integer", "example": 1 },
          "due_date": { "type": "string", "format": "date", "nullable": true },
          "status": {
            "type": "string",
            "enum": ["assigned", "completed", "approved", "rejected"],
