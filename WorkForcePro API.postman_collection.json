    {
      "name": "Employees",
      "item": [
        {
          "name": "GET All Employees",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// ============================================================",
                  "// GET /api/employees - Extract First Employee ID",
                  "// ============================================================",
                  "",
                  "// 1. Status Code Assertion",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// 2. Verify Response is Array",
                  "pm.test(\"Response is an array\", function () {",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "});",
                  "",
                  "// 3. Extract First Employee ID and Save to Environment",
                  "pm.test(\"Extract first employee ID and save to env\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    ",
                  "    // Find the first non-supervisor employee (is_supervisor = 0)",
                  "    // Skip API Test User (id: 19) and Bug Test One (id: 20) as they may be test data",
                  "    const firstEmployee = jsonData.find(emp => ",
                  "        emp.is_supervisor === 0 && ",
                  "        emp.id > 20 &&  // Skip test data (adjust as needed)",
                  "        emp.employee_id !== 'EMP999' &&",
                  "        emp.employee_id !== 'BUGTEST1'",
                  "    );",
                  "    ",
                  "    // Fallback: if no employee found, use the first employee with is_supervisor = 0",
                  "    const fallbackEmployee = jsonData.find(emp => emp.is_supervisor === 0);",
                  "    ",
                  "    const employeeToUse = firstEmployee || fallbackEmployee;",
                  "    ",
                  "    if (employeeToUse) {",
                  "        // Save to environment variables",
                  "        pm.environment.set(\"employeeId\", employeeToUse.id);",
                  "        pm.environment.set(\"employeeName\", employeeToUse.name);",
                  "        pm.environment.set(\"employeeEmail\", employeeToUse.email);",
                  "        pm.environment.set(\"employeeEmployeeId\", employeeToUse.employee_id);",
                  "        ",
                  "        console.log(\"✅ Selected Employee:\", {",
                  "            id: employeeToUse.id,",
                  "            name: employeeToUse.name,",
                  "            employee_id: employeeToUse.employee_id,",
                  "            email: employeeToUse.email",
                  "        });",
                  "    } else {",
                  "        console.log(\"❌ No employee found with is_supervisor = 0\");",
                  "    }",
                  "});",
                  "",
                  "// 4. Verify Environment Variable is Set",
                  "pm.test(\"Employee ID environment variable is set\", function () {",
                  "    pm.expect(pm.environment.get(\"employeeId\")).to.not.be.undefined;",
                  "    pm.expect(parseInt(pm.environment.get(\"employeeId\"))).to.be.a('number');",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/employees",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "employees"
              ]
            }
          },
          "response": []
